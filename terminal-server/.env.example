# Puerto donde corre el microservicio de terminal
TERMINAL_PORT=4000

# URL del frontend (Next.js) permitida para CORS/Socket.IO
FRONTEND_URL=http://localhost:3000

# Shell local por defecto cuando NO se conecta a un contenedor Vulhub
DEFAULT_SHELL=/bin/bash

# Máximo de sesiones de terminal concurrentes (protección básica anti-abuso)
MAX_SESSIONS=5

# Máximo de tiempo (ms) que una sesión puede vivir sin actividad antes de matarse
IDLE_TIMEOUT_MS=900000
